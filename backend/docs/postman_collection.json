{
  "info": {
    "name": "Task Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Aman Gupta\",\n  \"email\": \"aman@example.com\",\n  \"password\": \"secret123\"\n}" }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"aman@example.com\",\n  \"password\": \"secret123\"\n}" }
      }
    },
    {
      "name": "Auth - Me",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/auth/me" }
    },
    {
      "name": "Projects - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/projects",
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Website Redesign\",\n  \"description\": \"Q3 marketing site\"\n}" }
      }
    },
    {
      "name": "Projects - List",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/projects" }
    },
    {
      "name": "Projects - Add Member",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/projects/{{projectId}}/members",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"riya@example.com\"\n}" }
      }
    },
    {
      "name": "Tasks - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/projects/{{projectId}}/tasks",
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Design login page\",\n  \"priority\": \"HIGH\"\n}" }
      }
    },
    {
      "name": "Tasks - Update Status",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/tasks/{{taskId}}",
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" }
      }
    },
    {
      "name": "Tasks - List by Project",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/projects/{{projectId}}/tasks" }
    },
    {
      "name": "Search Tasks",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/search?q=login" }
    },
    {
      "name": "AI - Project Summary",
      "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/projects/{{projectId}}/summary" }
    }
  ]
}
